<?xml version="1.0" encoding="utf-8"?>
<xliff version="1.2" xmlns="urn:oasis:names:tc:xliff:document:1.2">
    <file source-language="en" datatype="plaintext" original="EXT:agent/Resources/Private/Language/locallang.xlf" date="2026-05-11T00:00:00Z" product-name="agent">
        <header/>
        <body>
            <trans-unit id="module.title" resname="module.title">
                <source>AI Tasks</source>
            </trans-unit>
            <trans-unit id="module.description" resname="module.description">
                <source>Create and manage AI agent tasks</source>
            </trans-unit>
            <trans-unit id="index.heading" resname="index.heading">
                <source>AI Tasks</source>
            </trans-unit>
            <trans-unit id="index.button.new" resname="index.button.new">
                <source>New Task</source>
            </trans-unit>
            <trans-unit id="index.placeholder" resname="index.placeholder">
                <source>Start a new task — describe what the AI should do…</source>
            </trans-unit>
            <trans-unit id="index.callout.selectPage" resname="index.callout.selectPage">
                <source>Please select a page in the page tree to start a new task.</source>
            </trans-unit>
            <trans-unit id="index.empty" resname="index.empty">
                <source>No tasks yet on this page. Start one above.</source>
            </trans-unit>
            <trans-unit id="index.section.current" resname="index.section.current">
                <source>Tasks on this page</source>
            </trans-unit>
            <trans-unit id="index.section.subpages" resname="index.section.subpages">
                <source>Tasks on subpages</source>
            </trans-unit>
            <trans-unit id="index.column.page" resname="index.column.page">
                <source>Page</source>
            </trans-unit>
            <trans-unit id="status.pending" resname="status.pending">
                <source>Pending</source>
            </trans-unit>
            <trans-unit id="status.inProgress" resname="status.inProgress">
                <source>In Progress</source>
            </trans-unit>
            <trans-unit id="status.ended" resname="status.ended">
                <source>Ended</source>
            </trans-unit>
            <trans-unit id="status.failed" resname="status.failed">
                <source>Failed</source>
            </trans-unit>
            <trans-unit id="status.cancelled" resname="status.cancelled">
                <source>Cancelled</source>
            </trans-unit>
            <trans-unit id="placeholder.page" resname="placeholder.page">
                <source>Describe what you'd like to create or change on page "%s", e.g. fix typos, add a new content element…</source>
            </trans-unit>
            <trans-unit id="placeholder.record" resname="placeholder.record">
                <source>Describe what you'd like to change on "%s" (%s), e.g. fix typos, revise the title…</source>
            </trans-unit>
            <trans-unit id="placeholder.default" resname="placeholder.default">
                <source>Describe the task you'd like the AI agent to perform, e.g. fix typos, revise the title…</source>
            </trans-unit>
            <trans-unit id="button.submit.title" resname="button.submit.title">
                <source>Start a new AI agent task (Enter)</source>
            </trans-unit>
            <trans-unit id="button.backToOrigin" resname="button.backToOrigin">
                <source>Back to origin</source>
            </trans-unit>
            <trans-unit id="button.backToTasks" resname="button.backToTasks">
                <source>Back to tasks list</source>
            </trans-unit>
            <trans-unit id="context.label" resname="context.label">
                <source>Task for %s</source>
            </trans-unit>
            <trans-unit id="workspace.label" resname="workspace.label">
                <source>Workspace</source>
            </trans-unit>
            <trans-unit id="workspace.live" resname="workspace.live">
                <source>Live</source>
            </trans-unit>
            <trans-unit id="workspace.callout.selectWorkspace" resname="workspace.callout.selectWorkspace">
                <source>Please switch to a workspace via the workspace selector in the top toolbar before starting a task. In the Live workspace changes go public immediately, so the agent does not write there.</source>
            </trans-unit>
            <trans-unit id="workspace.writingTo" resname="workspace.writingTo">
                <source>Writing in workspace: %s</source>
            </trans-unit>
            <trans-unit id="workspace.chat.mismatch" resname="workspace.chat.mismatch">
                <source>This task belongs to workspace "%s", but you are currently in "%s". Switch to "%s" to continue the conversation.</source>
            </trans-unit>
            <trans-unit id="workspace.chat.switchButton" resname="workspace.chat.switchButton">
                <source>Switch to workspace "%s"</source>
            </trans-unit>
            <trans-unit id="workspace.chat.switching" resname="workspace.chat.switching">
                <source>Switching workspace…</source>
            </trans-unit>
            <trans-unit id="tx_agent_instruction" resname="tx_agent_instruction">
                <source>Agent Instruction</source>
            </trans-unit>
            <trans-unit id="tx_agent_instruction.title" resname="tx_agent_instruction.title">
                <source>Name</source>
            </trans-unit>
            <trans-unit id="tx_agent_instruction.mode" resname="tx_agent_instruction.mode">
                <source>Mode</source>
            </trans-unit>
            <trans-unit id="tx_agent_instruction.mode.description" resname="tx_agent_instruction.mode.description">
                <source>"Always" adds the instruction body to the system prompt of every new chat (global base rule). "On demand" only lists the instruction in the prompt; the agent loads the full body via the GetInstruction tool when relevant.</source>
            </trans-unit>
            <trans-unit id="tx_agent_instruction.mode.always" resname="tx_agent_instruction.mode.always">
                <source>Always (in system prompt)</source>
            </trans-unit>
            <trans-unit id="tx_agent_instruction.mode.on_demand" resname="tx_agent_instruction.mode.on_demand">
                <source>On demand (loaded when relevant)</source>
            </trans-unit>
            <trans-unit id="tx_agent_instruction.description" resname="tx_agent_instruction.description">
                <source>When to use</source>
            </trans-unit>
            <trans-unit id="tx_agent_instruction.description.description" resname="tx_agent_instruction.description.description">
                <source>Short hint describing when this instruction applies, e.g. "When writing or revising texts for content elements or news". Shown in the prompt index so the agent knows when to load the full instruction.</source>
            </trans-unit>
            <trans-unit id="tx_agent_instruction.instruction" resname="tx_agent_instruction.instruction">
                <source>Instruction content</source>
            </trans-unit>
            <trans-unit id="tx_agent_instruction.instruction.description" resname="tx_agent_instruction.instruction.description">
                <source>The guidance itself — e.g. tone of voice, wording rules, or how to handle specific content elements or records.</source>
            </trans-unit>
            <trans-unit id="instructions.heading" resname="instructions.heading">
                <source>Agent instructions</source>
            </trans-unit>
            <trans-unit id="instructions.intro" resname="instructions.intro">
                <source>These instructions inform newly started chats. "Always" instructions are part of every prompt; "on-demand" instructions are loaded by the agent when relevant.</source>
            </trans-unit>
            <trans-unit id="instructions.badge.always" resname="instructions.badge.always">
                <source>always</source>
            </trans-unit>
            <trans-unit id="instructions.badge.onDemand" resname="instructions.badge.onDemand">
                <source>on-demand</source>
            </trans-unit>
            <trans-unit id="instructions.action.new" resname="instructions.action.new">
                <source>New instruction</source>
            </trans-unit>
            <trans-unit id="instructions.action.edit" resname="instructions.action.edit">
                <source>Edit instruction</source>
            </trans-unit>
            <trans-unit id="instructions.empty" resname="instructions.empty">
                <source>No instructions yet. Create one to give the agent reusable guidance (tone of voice, wording rules, how to handle specific content).</source>
            </trans-unit>
            <trans-unit id="instructions.column.id" resname="instructions.column.id">
                <source>ID</source>
            </trans-unit>
            <trans-unit id="instructions.column.name" resname="instructions.column.name">
                <source>Name</source>
            </trans-unit>
            <trans-unit id="instructions.column.mode" resname="instructions.column.mode">
                <source>Mode</source>
            </trans-unit>
            <trans-unit id="instructions.column.whenToUse" resname="instructions.column.whenToUse">
                <source>When to use</source>
            </trans-unit>
            <trans-unit id="instructions.column.content" resname="instructions.column.content">
                <source>Content</source>
            </trans-unit>
            <trans-unit id="instructions.action.show" resname="instructions.action.show">
                <source>Show</source>
            </trans-unit>
            <trans-unit id="instructions.modal.close" resname="instructions.modal.close">
                <source>Close</source>
            </trans-unit>
            <trans-unit id="instructions.action.disabled.workspace" resname="instructions.action.disabled.workspace">
                <source>Only editable in the Live workspace</source>
            </trans-unit>
        </body>
    </file>
</xliff>
